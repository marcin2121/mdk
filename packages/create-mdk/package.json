  "description": "Next.js Starter Kit with built-in GUI Setup Wizard",
  "bin": {
    "create-mdk": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --clean",
